{
  "imports": {
    "@std/assert": "jsr:@std/assert@1"
  },
  "tasks": {
    "dev": "deno run --allow-net --allow-read --allow-run --allow-env --allow-write --watch src/main.ts",
    "start": "deno run --allow-net --allow-read --allow-run --allow-env --allow-write src/main.ts",
    "build": "deno check src/main.ts && deno cache src/main.ts",
    "test": "deno test --allow-net --allow-read --allow-run --allow-env --allow-write src/",
    "lint": "deno lint",
    "fmt": "deno fmt --check"
  },
  "compilerOptions": {
    "lib": ["deno.window"]
  }
}
